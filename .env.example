# =============================================================================
# Solagracia — Environment Variables
# Copy to .env.local and fill in real values:
#   cp .env.example .env.local
# =============================================================================

# --- Supabase (required) -----------------------------------------------------
# Project: solagracia-radio — URL + anon from MCP / Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Legacy anon JWT (matches @supabase/ssr clients). Dashboard also shows
# sb_publishable_… keys; keep using the anon JWT for this app for now.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only — never expose to the browser (MCP cannot fetch this)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Site URL (optional) -----------------------------------------------------
# Used by next-sitemap at build time.
# Local: http://localhost:3000 · Vercel: your production URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
